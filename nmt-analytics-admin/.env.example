# Environment Configuration for NMT Analytics Admin

# Supabase Configuration
# Get these from: https://app.supabase.com > Your Project > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co

# IMPORTANT: Use the "anon" / "public" key here, NOT the service_role key!
# The service_role key should ONLY be used server-side (in the API).
# Using service_role in the browser is a critical security risk.
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# API URL (optional - defaults to /api which uses Vite proxy)
# VITE_API_URL=http://localhost:3001
