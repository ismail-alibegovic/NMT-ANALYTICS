# Environment Configuration for NMT Analytics API

# Node Environment
NODE_ENV=development

# Server Port (defaults to 3001 in development)
PORT=3001

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
# Optional. Used for client-side operations if provided.
SUPABASE_ANON_KEY=your-supabase-anon-key
# Required. Used for server-side operations and authentication.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin Frontend URL for CORS
# Optional. Defaults to http://localhost:5173 in development.
ADMIN_URL=http://localhost:5173

# Development Mode Bypass (NEVER use in production)
# DEV_BYPASS_AUTH=true
# DEV_ORG_ID=your-org-uuid-here

# Development Auto-Bootstrap (creates org/profile/modules automatically)
# DEV_AUTO_BOOTSTRAP=true
# DEV_DEFAULT_ORG_NAME=NMT Analytics
# DEV_DEFAULT_ROLE=director
# DEV_DEFAULT_MODULES=dashboard,customers,packages,reservations,departures,payments,transactions
