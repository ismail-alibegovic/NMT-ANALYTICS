# NMT Analytics production deployment variables
# Copy to .env on the production host. Never commit real secrets.

NODE_ENV=production
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public admin URL used by API CORS, no trailing slash
ADMIN_URL=https://your-admin-domain.com

# Production safety: keep these false/empty
DEV_BYPASS_AUTH=false
DEV_AUTO_BOOTSTRAP=false
